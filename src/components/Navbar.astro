---
import { Image } from "astro:assets";
import AppleIcon from "./icons/AppleIcon.astro";
import appIcon from "../assets/appicon.png";
---

<header class="sticky top-4 z-50 px-4">
    <nav
        class="mx-auto flex max-w-3xl items-center justify-between gap-4 rounded-full border border-white/20 bg-white/10 px-4 py-3 shadow-lg backdrop-blur-xl backdrop-saturate-150"
    >
        <a href="/" class="flex items-center gap-3">
            <Image
                src={appIcon}
                alt=""
                width={32}
                height={32}
                class="h-8 w-8 rounded-lg border border-black/2"
            />
            <span class="text-base font-medium tracking-tight">Voice Alarm</span
            >
        </a>

        <a
            href="#download"
            class="inline-flex items-center gap-2 rounded-full bg-black px-4 py-2 text-sm font-medium text-white transition hover:bg-black/80"
        >
            <AppleIcon class="h-4 w-4" />
            Download
        </a>
    </nav>
</header>
