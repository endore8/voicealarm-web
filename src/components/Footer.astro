---
const year = new Date().getFullYear();
---

<footer class="border-t border-slate-900/10 px-4 py-8">
	<div
		class="mx-auto flex max-w-4xl flex-col items-center justify-between gap-4 text-sm text-slate-500 sm:flex-row"
	>
		<p>© {year} Arka: Voice Alarm. All rights reserved.</p>
		<nav class="flex items-center gap-6">
			<a
				href="/privacy"
				class="transition hover:text-slate-900"
			>
				Privacy Policy
			</a>
			<a
				href="/terms"
				class="transition hover:text-slate-900"
			>
				Terms of Service
			</a>
		</nav>
	</div>
</footer>
