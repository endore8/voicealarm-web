---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <section class="flex grow items-center px-4 py-16">
        <div
            class="mx-auto flex max-w-xl flex-col items-center gap-6 text-center"
        >
            <p
                class="text-sm font-medium tracking-widest text-slate-500 uppercase"
            >
                404
            </p>
            <h1
                class="text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl"
            >
                This page is still asleep.
            </h1>
            <p class="text-lg text-slate-600">
                We couldn't find page you were looking for.
            </p>
            <a
                href="/"
                class="mt-2 inline-flex items-center gap-2 rounded-full bg-black px-5 py-3 text-sm font-medium text-white transition hover:bg-black/80"
            >
                Back home
            </a>
        </div>
    </section>
</Layout>
