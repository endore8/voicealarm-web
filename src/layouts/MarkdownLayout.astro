---
import Layout from "./Layout.astro";

interface Props {
	frontmatter: {
		title: string;
		updated?: string;
	};
}

const { frontmatter } = Astro.props;
---

<Layout>
	<article
		class="mx-auto max-w-3xl px-4 pt-16 pb-24 text-slate-700
			[&_h1]:text-4xl [&_h1]:font-bold [&_h1]:tracking-tight [&_h1]:text-slate-900 [&_h1]:mb-2
			[&_h2]:text-xl [&_h2]:font-medium [&_h2]:text-slate-900 [&_h2]:mt-10 [&_h2]:mb-3
			[&_p]:my-4 [&_p]:leading-relaxed
			[&_a]:text-slate-900 [&_a]:underline [&_a:hover]:text-slate-700
			[&_ul]:my-4 [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:space-y-2
			[&_strong]:text-slate-900 [&_strong]:font-medium"
	>
		<h1>{frontmatter.title}</h1>
		{
			frontmatter.updated && (
				<p class="!mt-1 text-sm text-slate-500">
					Last updated {frontmatter.updated}
				</p>
			)
		}
		<slot />
	</article>
</Layout>
